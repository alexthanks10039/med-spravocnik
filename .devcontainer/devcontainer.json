{
  "name": "MedSpravochnik Preview",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.12-bookworm",
  "forwardPorts": [8787],
  "portsAttributes": {
    "8787": {
      "label": "MedSpravochnik Preview",
      "onAutoForward": "openPreview"
    }
  },
  "postCreateCommand": "python -m pip install -r preview-codeplace/requirements-dev.txt",
  "postStartCommand": "bash -lc 'nohup python -m uvicorn app:app --app-dir preview-codeplace --host 0.0.0.0 --port 8787 > /tmp/med-preview.log 2>&1 &'"
}
